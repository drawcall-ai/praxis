{
  "version": "1.0",
  "student": "google/gemini-3-flash-preview",
  "schema": {
    "input": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "reviewText": {
          "type": "string",
          "description": "The product review to evaluate"
        }
      },
      "required": [
        "reviewText"
      ],
      "additionalProperties": false
    },
    "output": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "quality": {
          "type": "string",
          "enum": [
            "helpful",
            "unhelpful"
          ],
          "description": "Whether the review is helpful to other buyers"
        },
        "sentiment": {
          "type": "string",
          "enum": [
            "positive",
            "negative",
            "neutral"
          ],
          "description": "The overall sentiment of the review"
        },
        "hasSpecificDetails": {
          "type": "boolean",
          "description": "Whether the review mentions specific product details"
        }
      },
      "required": [
        "quality",
        "sentiment",
        "hasSpecificDetails"
      ],
      "additionalProperties": false
    }
  },
  "optimization": {
    "optimizer": "gepa",
    "instruction": "",
    "demos": [],
