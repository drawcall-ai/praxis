{
  "version": "1.0",
  "student": "google/gemini-3-flash-preview",
  "schema": {
    "input": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "reviewText": {
          "type": "string",
          "description": "The product review to evaluate"
        }
      },
      "required": [
        "reviewText"
      ],
      "additionalProperties": false
    },
    "output": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "quality": {
          "type": "string",
          "enum": [
            "helpful",
            "unhelpful"
          ],
          "description": "Whether the review is helpful to other buyers"
        },
        "sentiment": {
          "type": "string",
          "enum": [
            "positive",
            "negative",
            "neutral"
          ],
          "description": "The overall sentiment of the review"
        },
        "hasSpecificDetails": {
          "type": "boolean",
          "description": "Whether the review mentions specific product details"
        }
      },
      "required": [
        "quality",
        "sentiment",
        "hasSpecificDetails"
      ],
      "additionalProperties": false
    }
  },
  "optimization": {
    "instruction": "Analyze review. Return JSON:\n{\"quality\":\"helpful\" (useful info) | \"unhelpful\", \"sentiment\":\"positive\"|\"negative\"|\"neutral\", \"hasSpecificDetails\":bool (mentions specs/features/details)}",
    "reasoningEffort": "minimal",
    "bestScore": {
      "quality": 1,
      "sentiment": 1,
      "details": 1,
      "tokenEfficiency": 0.9723330090417415
    },
    "metricWeights": {
      "tokenEfficiency": 0.1
    },
    "evalRuns": [
      {
        "input": {
          "reviewText": "Screen resolution is 1080p, colors are accurate. Touch response is slightly laggy."
        },
        "expectedOutput": {
          "quality": "helpful",
          "sentiment": "neutral",
          "hasSpecificDetails": true
        },
        "modelOutput": {
          "quality": "helpful",
          "sentiment": "neutral",
          "hasSpecificDetails": true
        },
        "score": {
          "quality": 1,
          "sentiment": 1,
          "details": 1,
          "tokenEfficiency": 0.9720632783574554
        }
      },
      {
        "input": {
          "reviewText": "DO NOT BUY THIS PRODUCT"
        },
        "expectedOutput": {
          "quality": "unhelpful",
          "sentiment": "negative",
          "hasSpecificDetails": false
        },
        "modelOutput": {
          "quality": "unhelpful",
          "sentiment": "negative",
          "hasSpecificDetails": false
        },
        "score": {
          "quality": 1,
          "sentiment": 1,
          "details": 1,
          "tokenEfficiency": 0.9726027397260274
        }
      }
    ],
    "stats": {
