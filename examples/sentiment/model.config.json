{
  "version": "1.0",
  "student": "google/gemini-3-flash-preview",
  "teacher": "google/gemini-3.1-pro-preview",
  "schema": {
    "input": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "reviewText": {
          "type": "string",
          "description": "The text of the product review to analyze"
        }
      },
      "required": [
        "reviewText"
      ],
      "additionalProperties": false
    },
    "output": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "sentiment": {
          "type": "string",
          "enum": [
            "positive",
            "negative",
            "neutral"
          ],
          "description": "The overall sentiment of the review"
        },
        "confidence": {
          "type": "number",
          "description": "Confidence score between 0 and 1"
        }
      },
      "required": [
        "sentiment",
        "confidence"
      ],
      "additionalProperties": false
    }
  },
  "optimization": {
    "optimizer": "ace",
    "instruction": "## Sentiment Classification Guidelines\n- - Clear, unambiguous language expressing dissatisfaction (e.g., \"terrible\", \"broke\", \"would not recommend\", \"waste of money\") should result in a high-confidence negative sentiment classification.\n- - Clear, unambiguous language expressing satisfaction or praise (e.g., \"amazing\", \"fast\") should result in a high-confidence positive sentiment classification.\n- - Text that only states objective facts without evaluative language (e.g., \"It is a product. It exists.\") should be classified as neutral.\n- - Mild or lukewarm evaluative language (e.g., \"works fine\", \"nothing special\") expresses a degree of satisfaction or dissatisfaction and should be classified as positive or negative, not neutral. Neutral sentiment is strictly reserved for objective, factual statements.",
    "demos": [],
    "bestScore": 1,
    "evalRuns": [
      {
        "input": {
          "reviewText": "Five stars! Exceeded my expectations."
        },
        "expectedOutput": {
          "sentiment": "positive",
          "confidence": 0.97
        },
        "modelOutput": {
          "sentiment": "positive",
          "confidence": 1
        },
        "score": 1
      },
      {
        "input": {
          "reviewText": "Arrived damaged and support was unhelpful."
