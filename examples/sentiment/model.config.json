        "expectedOutput": {
          "sentiment": "negative",
          "confidence": 0.91
        },
        "modelOutput": {
          "sentiment": "negative",
          "confidence": 0.98
        },
        "score": 1
      },
      {
        "input": {
          "reviewText": "The product is okay for the price."
        },
        "expectedOutput": {
          "sentiment": "neutral",
          "confidence": 0.75
        },
        "modelOutput": {
          "sentiment": "neutral",
          "confidence": 0.95
        },
        "score": 1
      },
      {
